{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Garita SK-XII",
  "version": "0.3.2",
  "identifier": "com.shikillo.garita",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Garita",
        "width": 1280,
        "height": 840,
        "minWidth": 1000,
        "minHeight": 660
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
